{
    "name": "hanzokms/php-sdk",
    "description": "Official PHP SDK for Hanzo KMS",
    "type": "library",
    "license": "BSD-3-Clause",
    "authors": [
        {
            "name": "Hanzo AI, Inc.",
            "email": "engineering@hanzo.ai"
        }
    ],
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0",
        "cuyz/valinor": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "phpstan/phpstan": "^1.0",
        "squizlabs/php_codesniffer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "HanzoKms\\SDK\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HanzoKms\\SDK\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse src",
        "cs": "phpcs src",
        "cs-fix": "phpcbf src"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
